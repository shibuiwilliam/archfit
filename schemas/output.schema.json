{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archfit.dev/schemas/output.schema.json",
  "title": "archfit scan output",
  "description": "Structured report emitted by `archfit scan --json`. Agents consume this; breaking changes require a major bump.",
  "type": "object",
  "required": ["schema_version", "tool", "target", "summary", "scores", "findings", "metrics"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.[0-9]+\\.[0-9]+$",
      "description": "Output schema version. Pre-1.0. Minor bumps may add fields; major bumps may rename/remove."
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {"const": "archfit"},
        "version": {"type": "string"}
      }
    },
    "target": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "git": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commit": {"type": "string"},
            "branch": {"type": "string"}
          }
        },
        "profile": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "required": ["rules_evaluated", "rules_with_findings", "findings_total", "by_severity"],
      "additionalProperties": false,
      "properties": {
        "rules_evaluated": {"type": "integer", "minimum": 0},
        "rules_with_findings": {"type": "integer", "minimum": 0},
        "findings_total": {"type": "integer", "minimum": 0},
        "by_severity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "info": {"type": "integer", "minimum": 0},
            "warn": {"type": "integer", "minimum": 0},
            "error": {"type": "integer", "minimum": 0},
            "critical": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall", "by_principle"],
      "additionalProperties": false,
      "properties": {
        "overall": {"type": "number", "minimum": 0, "maximum": 100},
        "by_principle": {
          "type": "object",
          "patternProperties": {
            "^P[1-7]$": {"type": "number", "minimum": 0, "maximum": 100}
          },
          "additionalProperties": false
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "principle", "severity", "evidence_strength", "confidence", "path", "message", "evidence", "remediation"],
        "additionalProperties": false,
        "properties": {
          "rule_id": {"type": "string", "pattern": "^P[1-7]\\.[A-Z]{3}\\.[0-9]{3}$"},
          "principle": {"type": "string", "enum": ["P1","P2","P3","P4","P5","P6","P7"]},
          "severity": {"type": "string", "enum": ["info","warn","error","critical"]},
          "evidence_strength": {"type": "string", "enum": ["strong","medium","weak","sampled"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "path": {"type": "string"},
          "message": {"type": "string"},
          "evidence": {"type": "object"},
          "remediation": {
            "type": "object",
            "required": ["summary"],
            "additionalProperties": false,
            "properties": {
              "summary": {"type": "string"},
              "guide_ref": {"type": "string"},
              "auto_fixable": {"type": "boolean"}
            }
          },
          "llm_suggestion": {
            "type": "object",
            "description": "Present only when --with-llm is used. Omitted otherwise.",
            "additionalProperties": false,
            "properties": {
              "text": {"type": "string"},
              "model": {"type": "string"},
              "cache_hit": {"type": "boolean"},
              "truncated": {"type": "boolean"},
              "latency_ms": {"type": "integer", "minimum": 0},
              "input_tokens": {"type": "integer", "minimum": 0},
              "output_tokens": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "value": {"type": "number"},
          "unit": {"type": "string"},
          "principle": {"type": "string"}
        }
      }
    }
  }
}
