# archfit — example local environment.
# Copy to .env and fill in real values. .env is in .gitignore; .env.example is tracked.

# --- LLM (Phase 3a, opt-in via `--with-llm`) --------------------------------
# archfit reads GOOGLE_API_KEY first, falls back to GEMINI_API_KEY.
# Get a key: https://ai.google.dev/gemini-api/docs/api-key
export GOOGLE_API_KEY='your-gemini-api-key'
# export GEMINI_API_KEY='alternative-env-var'

# Override the default model (see docs/llm.md).
# export LLM_MODEL='gemini-2.5-flash'
