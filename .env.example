# archfit — example local environment.
# Copy to .env and fill in real values. .env is in .gitignore; .env.example is tracked.

# --- LLM (opt-in via `--with-llm`) -------------------------------------------
# archfit auto-detects the backend from whichever key is set.
# Priority: ANTHROPIC_API_KEY > OPENAI_API_KEY > GOOGLE_API_KEY > GEMINI_API_KEY.
# Override with: --llm-backend={gemini|openai|claude}

# Claude — https://console.anthropic.com/settings/keys
# export ANTHROPIC_API_KEY='your-anthropic-api-key'

# OpenAI — https://platform.openai.com/api-keys
# export OPENAI_API_KEY='your-openai-api-key'

# Gemini — https://ai.google.dev/gemini-api/docs/api-key
export GOOGLE_API_KEY='your-gemini-api-key'
# export GEMINI_API_KEY='alternative-env-var'

# Override the default model (gemini-2.5-flash, gpt-5.4-mini, or claude-sonnet-4-6-20250627).
# export LLM_MODEL='gemini-2.5-flash'
